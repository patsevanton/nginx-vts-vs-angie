{
  "dashboard": {
    "title": "Nginx-VTS vs Angie Benchmark",
    "tags": ["benchmark", "nginx", "angie"],
    "timezone": "browser",
    "panels": [
      {
        "title": "RPS by Variant",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "sum by (variant) (rate(nginx_vts_requests_total{variant=~\".*\"}[1m]))",
            "legendFormat": "{{variant}}"
          }
        ]
      },
      {
        "title": "Response Time P95 by Variant",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum by (le, variant) (rate(nginx_vts_request_duration_seconds_bucket[5m])))",
            "legendFormat": "{{variant}} p95"
          }
        ]
      },
      {
        "title": "Bytes Received (Ingress Traffic)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "sum by (variant) (rate(nginx_vts_bytes_total{direction=\"in\"}[1m]))",
            "legendFormat": "{{variant}} bytes_in/s"
          }
        ]
      },
      {
        "title": "Bytes Sent (Egress Traffic)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "sum by (variant) (rate(nginx_vts_bytes_total{direction=\"out\"}[1m]))",
            "legendFormat": "{{variant}} bytes_out/s"
          }
        ]
      },
      {
        "title": "HTTP Status Codes by Variant",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
        "targets": [
          {
            "expr": "sum by (variant, status) (rate(nginx_vts_requests_total[1m]))",
            "legendFormat": "{{variant}} {{status}}"
          }
        ]
      },
      {
        "title": "CPU Usage by Variant",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
        "targets": [
          {
            "expr": "rate(process_cpu_seconds_total{job=~\"nginx-vts-exporter|angie-api\", variant=~\".*\"}[1m])",
            "legendFormat": "{{variant}} cpu"
          }
        ]
      },
      {
        "title": "Vector Processed Events",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
        "targets": [
          {
            "expr": "sum by (variant) (rate(vector_events_in_total{component=~\".*\"}[1m]))",
            "legendFormat": "{{variant}} events/s"
          }
        ]
      },
      {
        "title": "Vector Processed Bytes",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
        "targets": [
          {
            "expr": "sum by (variant) (rate(vector_processed_bytes_total[1m]))",
            "legendFormat": "{{variant}} bytes/s"
          }
        ]
      }
    ],
    "refresh": "10s",
    "time": { "from": "now-30m", "to": "now" }
  },
  "overwrite": true
}
